(function($){$(document).ready(function(){window.showAddress=function(addressId){console.log("showAddress triggered for:",addressId);$(".address-box").hide();var addressContent=$("#"+addressId).html();if(addressContent){$("#address-content").html('<div class="address-box">'+addressContent+'</div>')}else{console.error("No content found for addressId:",addressId)}};$(".marker").on("click",function(){var markerId=$(this).data("address-id");if(markerId){showAddress(markerId)}else{console.error("No address ID associated with this marker.")}})})})(jQuery)